# PENTeam Environment Configuration
# For macOS with Ollama running on the host machine
# Copy this file to .env and customize as needed

#==============================================================================
# OLLAMA CONFIGURATION (Running on macOS Host)
#==============================================================================

# Ollama runs on macOS host, container accesses via host.docker.internal
# Default port: 11434
OLLAMA_HOST=host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Agent-specific models (lightweight for local inference)
# Adjust based on your hardware capabilities

# Coordinator and review agents - general purpose
SUPERVISOR_MODEL=llama3.2:3b
CREATIVE_MATH_MODEL=llama3.2:3b
SENIOR_MATH_MODEL=llama3.2:3b
TESTER_MODEL=llama3.2:3b

# Code generation - use code-specialized model
PYTHON_CODER_MODEL=codellama:7b

#==============================================================================
# OPENAI FALLBACK (Cloud Models - Optional)
#==============================================================================
# Uncomment and fill in if you prefer cloud-based models or Ollama is unavailable

# LLM_API_KEY=your-openai-api-key
# LLM_MODEL=gpt-4
# LLM_BASE_URL=https://api.openai.com/v1

#==============================================================================
# DOCKER SETTINGS
#==============================================================================

# Container name
CONTAINER_NAME=pent-eam-math-team

# Image name
IMAGE_NAME=pent-eam-math-team:latest

# Port for OpenHands API
OPENHANDS_PORT=3000

#==============================================================================
# MODEL CUSTOMIZATION FOR MACBOOK M-SERIES
#==============================================================================
# Apple Silicon (M1-M5) Macs are very efficient for local inference

# M5 Pro/Max recommended (more RAM available):
# SUPERVISOR_MODEL=llama3.2:3b
# CREATIVE_MATH_MODEL=llama3.2:3b
# SENIOR_MATH_MODEL=llama3.2:3b
# PYTHON_CODER_MODEL=codellama:13b  # Larger model for better code
# TESTER_MODEL=llama3.2:3b

# M5/M4 base (less RAM, use smaller models):
# SUPERVISOR_MODEL=llama3.2:1b
# CREATIVE_MATH_MODEL=llama3.2:1b
# SENIOR_MATH_MODEL=llama3.2:1b
# PYTHON_CODER_MODEL=codellama:7b
# TESTER_MODEL=llama3.2:1b

# Math-specialized models (if available):
# CREATIVE_MATH_MODEL=mathstral:7b
# SENIOR_MATH_MODEL=mathstral:7b